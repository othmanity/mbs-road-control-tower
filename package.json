{
  "name": "mbs-road-control-tower",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "server": "tsx watch server/index.ts",
