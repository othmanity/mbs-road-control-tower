# Anthropic API key — required for the Ask Control Tower Agent
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Backend port (defaults to 3001)
# PORT=3001

# Frontend → backend URL for production (Vercel)
# When empty (local dev), frontend uses /api/* via Vite proxy.
# In production set to your Railway URL, e.g.:
# VITE_API_BASE_URL=https://mbs-ct-backend-production.up.railway.app
